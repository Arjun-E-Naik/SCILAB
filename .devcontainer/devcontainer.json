{
  "name": "FOSSEE IP Toolbox - Scilab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {},

  "onCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "dakara.transformer",
        "ms-vscode.hexeditor"
      ],
      "settings": {
        "files.associations": {
          "*.sce": "scilab",
          "*.sci": "scilab"
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": "echo '✅ Scilab environment ready! Run: bash tests/run_all_tests.sh'",

  "remoteUser": "vscode"
}